{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "A multi-tenant workspace container.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "stripeCustomerId": { "type": "string" },
        "stripeSubscriptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "WorkspaceMember": {
      "title": "WorkspaceMember",
      "description": "Membership link between a User and a Workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workspaceId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent", "viewer"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "workspaceId", "role"]
    },
    "UsageLog": {
      "title": "UsageLog",
      "description": "Tracks billable actions within a workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "actionType": { "type": "string" },
        "cost": { "type": "number" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "actionType", "cost"]
    },
    "Property": {
      "title": "Property",
      "description": "A managed real estate asset.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "address": { "type": "string" },
        "units": { "type": "number" },
        "occupied": { "type": "number" },
        "monthly_rent": { "type": "number" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "maintenance", "vacant"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["address", "ownerId", "workspaceId"]
    },
    "Deal": {
      "title": "Deal",
      "description": "An acquisition opportunity (DealFlow).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "title": { "type": "string" },
        "address": { "type": "string" },
        "price": { "type": "number" },
        "arv": { "type": "number" },
        "rehabCost": { "type": "number" },
        "score": { "type": "number" },
        "status": { "type": "string", "enum": ["new", "analyzing", "offer-sent", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["address", "price", "workspaceId"]
    },
    "Buyer": {
      "title": "Buyer",
      "description": "A potential investor or buyer (BuyerFlow).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "budget": { "type": "number" },
        "location": { "type": "string" },
        "strategy": { "type": "string", "enum": ["fix-and-flip", "buy-and-hold", "cash-quick-close", "first-time"] },
        "intentScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "budget", "workspaceId"]
    },
    "Match": {
      "title": "Match",
      "description": "A match between a Deal and a Buyer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "dealId": { "type": "string" },
        "buyerId": { "type": "string" },
        "score": { "type": "number" },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "contacted", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "buyerId", "score", "workspaceId"]
    }
  },
  "firestore": {
    "/workspaces/{workspaceId}": { "schema": "Workspace", "description": "Workspace containers" },
    "/workspaceMembers/{memberId}": { "schema": "WorkspaceMember", "description": "Memberships" },
    "/usageLogs/{logId}": { "schema": "UsageLog", "description": "Metering logs" },
    "/properties/{propertyId}": { "schema": "Property", "description": "Managed properties (scoped by workspaceId)" },
    "/deals/{dealId}": { "schema": "Deal", "description": "Acquisition deals (scoped by workspaceId)" },
    "/buyers/{buyerId}": { "schema": "Buyer", "description": "Investor leads (scoped by workspaceId)" },
    "/matches/{matchId}": { "schema": "Match", "description": "Deal-to-buyer matches (scoped by workspaceId)" }
  }
}
