rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isMember(workspaceId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/workspaceMembers/$(request.auth.uid + "_" + workspaceId));
    }
    
    function getRole(workspaceId) {
      return get(/databases/$(database)/documents/workspaceMembers/$(request.auth.uid + "_" + workspaceId)).data.role;
    }

    function isAdmin(workspaceId) {
      return isMember(workspaceId) && getRole(workspaceId) == 'admin';
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isMember(workspaceId));
      allow create: if isSignedIn(); // Allow creating new workspaces
      allow update: if isAdmin(workspaceId);
    }

    // Workspace Memberships
    // Using custom IDs like userId_workspaceId for easy lookups
    match /workspaceMembers/{memberId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMember(resource.data.workspaceId));
      allow create: if isSignedIn(); // Allow joining or following creation logic
      allow delete: if isAdmin(resource.data.workspaceId);
    }

    // Usage Logs (Metering)
    match /usageLogs/{logId} {
      allow read: if isAdmin(resource.data.workspaceId);
      allow create: if isMember(request.resource.data.workspaceId);
      allow update, delete: if false; // Immutable logs
    }

    // Business Entities (Scoped)
    match /properties/{propertyId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isMember(request.resource.data.workspaceId);
      allow update: if isMember(resource.data.workspaceId);
      allow delete: if isAdmin(resource.data.workspaceId);
    }

    match /deals/{dealId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isMember(request.resource.data.workspaceId);
      allow update: if isMember(resource.data.workspaceId);
      allow delete: if isAdmin(resource.data.workspaceId);
    }

    match /buyers/{buyerId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isMember(request.resource.data.workspaceId);
      allow update: if isMember(resource.data.workspaceId);
      allow delete: if isAdmin(resource.data.workspaceId);
    }

    match /matches/{matchId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isMember(request.resource.data.workspaceId);
      allow update: if isMember(resource.data.workspaceId);
      allow delete: if isAdmin(resource.data.workspaceId);
    }
  }
}
